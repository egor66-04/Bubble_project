# =============================================================================
# BUBBLE DJANGO PROJECT — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Collected static files (production)
staticfiles/
static_root/

# Media files (user uploads — store on S3/CDN in production)
media/
!media/.gitkeep

# Django migrations — KEEP (they define DB schema)
# DO NOT add migrations/ to .gitignore

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
*.pem
*.key
secrets.json

# -----------------------------------------------------------------------------
# IDEs and Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Node.js (if any frontend tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
.cache/
